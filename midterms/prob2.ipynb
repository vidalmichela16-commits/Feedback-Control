     "output_type": "display_data"
    }
   ],
   "source": [
    "# 3. Generate Step Response Plot\n",
    "# Compute the response to a unit step input\n",
    "t, y = ctrl.step_response(G)\n",
    "\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.plot(t, y, color='#0d9488', linewidth=2)\n",
    "plt.title('System Step Response')\n",
    "plt.xlabel('Time (s)')\n",
    "plt.ylabel('Output')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "95bf010e",
