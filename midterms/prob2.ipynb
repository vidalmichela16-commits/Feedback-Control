      "Transfer Function:\n",
      "G(s) = <TransferFunction>: sys[0]\n",
      "Inputs (1): ['u[0]']\n",
      "Outputs (1): ['y[0]']\n",
      "\n",
      "              1\n",
      "  -------------------------\n",
      "  s^4 + 2 s^3 + 3 s^2 + 2 s\n"
     ]
    }
   ],
   "source": [
    "import control as ctrl\n",
"import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Define the coefficients of the transfer function\n",
    "# Numerator: 1\n",
    "# Denominator: s^4 + 2s^3 + 3s^2 + 2s + 0\n",
    "num = [1]\n",
    "den = [1, 2, 3, 2, 0]\n",
    "\n",
    "# 1. Create and Print the Transfer Function\n",
    "G = ctrl.TransferFunction(num, den)\n",
    "print(\"Transfer Function:\")\n",
    "print(f\"G(s) = {G}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "b557ab07",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Poles: [-0.5+1.32287566j -0.5-1.32287566j -1. +0.j          0. +0.j        ]\n",
      "Zeros: []\n"
     ]
    }
   ],
   "source": [
    "# 2. Calculate and Print Poles and Zeros\n",
    "poles = ctrl.poles(G)\n",
    "zeros = ctrl.zeros(G)\n",
    "print(f\"Poles: {poles}\")\n",
    "print(f\"Zeros: {zeros}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d93c92c1",
   "metadata": {},
   "outputs": [
    {
     "data": {
