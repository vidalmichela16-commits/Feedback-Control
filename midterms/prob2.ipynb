     "output_type": "display_data"
    }
   ],
   "source": [
    "# 4. Generate Pole-Zero Map\n",
    "# Visualize the poles and zeros on the complex plane\n",
    "plt.figure(figsize=(8, 6))\n",
    "ctrl.pzmap(G, grid=True)\n",
    "plt.title('Pole-Zero Map of the System')\n",
    "plt.show()"
   ]
  }
