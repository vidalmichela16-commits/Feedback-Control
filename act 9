# Libraries
import sympy as sp
import numpy as np
import matplotlib.pyplot as plt
from control import TransferFunction, step_response, pzmap, poles, zeros

# Define Laplace variable
s = sp.symbols('s')

# Define symbolic input/output
U, Y = sp.symbols('U Y')

# Define equation (rearranged form)
# 2s^2 Y + sY - sU - U = 0
expr = 2*s**2 * Y + s*Y - s*U - U

# Solve for Y in terms of U
solution = sp.solve(expr, Y)[0]

# Get transfer function G(s) = Y/U
G = sp.simplify(solution / U)
print("Transfer Function G(s):", G)

# Extract numerator and denominator
num_poly = sp.Poly(sp.numer(G), s)
den_poly = sp.Poly(sp.denom(G), s)

num = [float(i) for i in num_poly.all_coeffs()]
den = [float(i) for i in den_poly.all_coeffs()]

# Create transfer function system
sys = TransferFunction(num, den)
print("\nSystem Representation:")
print(sys)

# Poles and zeros
print("\nPoles:", poles(sys))
print("Zeros:", zeros(sys))

# Step response
t, y = step_response(sys)

plt.figure()
plt.plot(t, y)
plt.title("Step Response of the System")
plt.xlabel("Time (seconds)")
plt.ylabel("Output")
plt.grid()
plt.show()

# Pole-zero map
plt.figure()
pzmap(sys, plot=True)
plt.title("Pole-Zero Map")
plt.show()
